# =============================================================================
# Easy Memory — 环境变量配置模板
# =============================================================================
# cp .env.example .env && vim .env
# =============================================================================

# ---- 运行模式 ----
EASY_MEMORY_MODE=http               # mcp | http

# ---- Qdrant ----
QDRANT_URL=http://qdrant:6333       # Docker 内部网络地址
QDRANT_API_KEY=change-me-to-a-strong-key

# ---- Embedding ----
# 向量模型引擎选择:
#   ollama — 仅使用本地 Ollama (默认, 无需额外配置)
#   gemini — 仅使用远端 Google Gemini (需要 API Key)
#   auto   — Gemini 优先, Ollama 自动兜底 (推荐生产环境)
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434 # Docker 内部网络地址
OLLAMA_MODEL=bge-m3

# ⚠️ 使用 Gemini 远端向量模型:
#   1. 前往 https://aistudio.google.com/apikey 申请免费 API Key
#   2. 填入下方 GEMINI_API_KEY
#   3. 将 EMBEDDING_PROVIDER 改为 auto (推荐) 或 gemini
#   如果不配置, 系统将仅使用本地 Ollama 模型
GEMINI_API_KEY=

# ---- HTTP API ----
HTTP_AUTH_TOKEN=change-me-to-a-strong-token
HTTP_HOST=0.0.0.0
HTTP_PORT=3080
TRUST_PROXY=false                   # 反向代理后设为 true
REQUIRE_TLS=false                   # 有 HTTPS 后设为 true

# ---- Application ----
DEFAULT_PROJECT=default

# ---- Docker Compose Ports (可选) ----
# QDRANT_PORT=6333
# QDRANT_GRPC_PORT=6334
# OLLAMA_PORT=11434
