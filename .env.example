# =============================================================================
# Easy Memory — 环境变量配置模板
# =============================================================================
# cp .env.example .env && vim .env
# =============================================================================

# ---- 运行模式 ----
EASY_MEMORY_MODE=http               # mcp | http

# ---- Qdrant ----
QDRANT_URL=http://qdrant:6333       # Docker 内部网络地址
QDRANT_API_KEY=change-me-to-a-strong-key

# ---- Embedding ----
# 向量模型引擎选择:
#   ollama — 仅使用本地 Ollama (默认, 无需额外配置)
#   gemini — 仅使用远端 Google Gemini (需要 API Key)
#   auto   — Gemini 优先, Ollama 自动兜底 (推荐生产环境)
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434 # Docker 内部网络地址
OLLAMA_MODEL=bge-m3

# ⚠️ 使用 Gemini 远端向量模型 (Google Cloud Vertex AI):
#   1. 前往 Google Cloud Console 创建 API Key
#   2. 填入下方 GEMINI_API_KEY 和 GEMINI_PROJECT_ID
#   3. 将 EMBEDDING_PROVIDER 改为 auto (推荐) 或 gemini
#   如果不配置, 系统将仅使用本地 Ollama 模型
GEMINI_API_KEY=
GEMINI_PROJECT_ID=
GEMINI_REGION=us-central1

# ---- HTTP API ----
HTTP_AUTH_TOKEN=change-me-to-a-strong-token
HTTP_HOST=0.0.0.0
HTTP_PORT=3080

# ---- Admin API ----
# Admin Token 用于访问管理后台 (/api/admin/*)
# 包括: API Key 管理、用量分析、审计日志导出、运行时配置
# 留空则禁用 Admin 功能
ADMIN_TOKEN=change-me-to-admin-token
ADMIN_USERNAME=admin                # Web UI 管理员用户名 (首次启动自动创建)
ADMIN_PASSWORD=change-me-to-admin-password  # Web UI 管理员密码
TRUST_PROXY=false                   # 反向代理后设为 true
REQUIRE_TLS=false                   # 有 HTTPS 后设为 true

# ---- Application ----
DEFAULT_PROJECT=default

# ---- Data Persistence ----
# SQLite 数据库、审计日志、运行时配置的存储目录
# Docker 部署时自动设为 /data (已 volume 挂载)
# 本地开发默认使用 $HOME 目录
# DATA_DIR=/data

# ---- Docker Compose Ports (可选) ----
# QDRANT_PORT=6333
# QDRANT_GRPC_PORT=6334
# OLLAMA_PORT=11434
